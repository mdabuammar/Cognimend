.env
.env.local
.env.*
!.env.example
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env.production
*.env

# API Keys and Secrets
*.pem
*.key
*.p12
*.pfx
secrets/
.secrets/
api-keys.json
credentials.json

# =============================================================================
# Dependencies
# =============================================================================
node_modules/
frontend/node_modules/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
.venv/
env/
ENV/

# =============================================================================
# IDE and Editors
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# =============================================================================
