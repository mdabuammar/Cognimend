# Environment Variables - CRITICAL: Never commit .env files!
# Copy this file to .env and fill in your values

# =============================================================================
# API URLs (Required)
# =============================================================================
VITE_API_URL=http://localhost:8001
VITE_QUERY_API_URL=http://localhost:8002
VITE_TELEMETRY_API_URL=http://localhost:8003
VITE_DRIFT_DETECTOR_API_URL=http://localhost:8004

# =============================================================================
# Authentication (Required for Production)
# =============================================================================
# Auth API URL - Set this to enable real authentication
# When not set, the app runs in demo mode with fake auth
# VITE_AUTH_API_URL=https://api.yourapp.com/auth

# =============================================================================
# External Services (Optional)
# =============================================================================

# Supabase - If using Supabase for auth/database
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry - Error tracking (production)
# VITE_SENTRY_DSN=https://your-sentry-dsn

# Analytics
# VITE_ANALYTICS_ID=your-analytics-id

# =============================================================================
# Production Environment Settings
# =============================================================================
# NODE_ENV=production
# VITE_ENABLE_DEVTOOLS=false

# =============================================================================
# Backend Environment Variables
# =============================================================================
# These should be set in the backend .env file, not the frontend

# OPENAI_API_KEY=<your-openai-api-key>
# QDRANT_API_KEY=your-qdrant-key
# DATABASE_URL=postgresql://user:pass@localhost:5432/ragdb
# REDIS_URL=redis://localhost:6379
