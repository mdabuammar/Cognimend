# =============================================================================
# Backend .gitignore
# =============================================================================

# Environment and Secrets - CRITICAL
.env
.env.*
!.env.example
*.pem
*.key
secrets/
.secrets/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
.installed.cfg
*.egg
venv/
.venv/
ENV/
pip-wheel-metadata/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
logs/
*.log

# Data files (keep structure, ignore uploads)
data/uploads/*
!data/uploads/.gitkeep

# Docker
*.tar
docker-compose.override.yml

# OS
.DS_Store
Thumbs.db
